<Window
    x:Class="Pacman.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="#F5F7FB">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111827" Padding="28">
            <StackPanel VerticalAlignment="Center" Spacing="18">
                <Image Source="Assets/pacman.gif" Width="120" Height="120"/>
                <TextBlock Text="Pacman Uninstaller"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="Bold"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Válaszd ki az alkalmazást, Pacman pedig látványosan eltünteti."
                           Foreground="#CBD5E1"
                           FontSize="15"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Padding="34">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Spacing="10">
                <TextBlock Text="Telepített programok"
                           FontSize="34"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>

                <TextBox PlaceholderText="Keresés név vagy kiadó alapján..."
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="16"
                         Height="46"/>
            </StackPanel>

            <ListView Grid.Row="1"
                      Margin="0,24,0,0"
                      ItemsSource="{Binding Programs}"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White"
                                CornerRadius="16"
                                Padding="18"
                                Margin="0,0,0,12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="5">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"/>

                                    <TextBlock Text="{Binding Publisher}"
                                               FontSize="13"
                                               Foreground="#64748B"/>

                                    <TextBlock Text="{Binding DisplayVersion}"
                                               FontSize="12"
                                               Foreground="#94A3B8"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Eltávolítás"
                                        Click="UninstallButton_Click"
                                        IsEnabled="{Binding CanUninstall}"
                                        Padding="18,8"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Window>